<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1976D2"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:text="Complete Task Form"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="20dp">

            <TextView
                android:text="Add New Task"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#483d8B"
                android:layout_marginBottom="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Task Title"
                android:textColor="#1976D2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter task title..."
                android:inputType="text"
                android:background="@drawable/bg_edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:text="Description"
                android:textColor="#1976D2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editTaskDesc"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Enter description..."
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/bg_edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:text="Due date"
                android:textColor="#1976D2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editDueDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="dd/MM/yyyy"
                android:inputType="date"
                android:background="@drawable/bg_edittext_border"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <CheckBox
                android:id="@+id/checkCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mark completed"
                android:layout_marginBottom="24dp" />

            <TextView
                android:text="Priority"
                android:textColor="#1976D2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/radioGroupPriority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radioLow"
                    android:text="Low"
                    android:checked="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"/>

                <RadioButton android:id="@+id/radioMed"
                    android:text="Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"/>

                <RadioButton android:id="@+id/radioHigh"
                    android:text="High"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </RadioGroup>

            <TextView
                android:text="Category"
                android:textColor="#1976D2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_edittext_border"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:drawable/btn_dropdown" />
            </FrameLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SAVE TASK"
                android:textStyle="bold"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>